#include <Servo.h>

// Cria os servos
Servo servoDormindo;
Servo servoAcordado;

// Sensor de som
int sensorSom = A0;

// Variáveis
int valorSom = 0;
int mediaSom = 0;
int angulo = 0;

void setup() {

  Serial.begin(9600);

  // Pinos dos servos
  servoDormindo.attach(9);
  servoAcordado.attach(10);

  // Estado inicial
  servoDormindo.write(90);
  servoAcordado.write(0);
}

void loop() {

  mediaSom = 0;

  // Faz média do som
  for (int i = 0; i < 10; i++) {
    mediaSom += analogRead(sensorSom);
    delay(2);
  }

  valorSom = mediaSom / 10;

  Serial.println(valorSom);

  // Silêncio
  if (valorSom > 950) {

    angulo = 0;

  }

  // Som médio
  else if (valorSom > 850) {

    angulo = 45;

  }

  // Muito barulho
  else {

    angulo = 90;

  }

  // Move os servos
  servoDormindo.write(180 - angulo);
  servoAcordado.write(angulo);

  delay(150);
}
